# Copy this file to ".env" and fill in real values. NEVER commit the real .env.
#
# GMAIL_APP_PASSWORD is a 16-character Google "App Password" (NOT your Gmail login password).
# To create one: Google Account → Security → turn on 2-Step Verification →
# search "App passwords" → create one named "CED Website" → paste the 16-char code here.
GMAIL_USER=forms.ced@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
RECIPIENT_EMAIL=forms.ced@gmail.com
PORT=3000
